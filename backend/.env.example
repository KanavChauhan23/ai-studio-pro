# AI Studio Pro - Environment Variables

# App Settings
APP_NAME=AI Studio Pro
APP_VERSION=1.0.0
DEBUG=True

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/ai_studio_pro

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (Frontend URLs)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# AI Service API Keys
GROQ_API_KEY=your-groq-api-key-here
REPLICATE_API_KEY=your-replicate-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here-optional

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
