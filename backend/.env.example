# AI Studio Pro - Environment Variables (Updated for Supabase)

# App Settings
APP_NAME=AI Studio Pro
APP_VERSION=1.0.0
DEBUG=True

# ============================================================
# DATABASE (Supabase PostgreSQL)
# ============================================================
# Go to: https://supabase.com → Your Project → Settings → Database
# Copy the "URI" connection string under "Connection string" tab
# Replace [YOUR-PASSWORD] with your actual database password
#
# FORMAT:
# postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
#
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS (Frontend URLs)
CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# AI Service API Keys
GROQ_API_KEY=your-groq-api-key-here
REPLICATE_API_KEY=your-replicate-api-key-here
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here-optional

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
